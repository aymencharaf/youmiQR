// Youmi - Algerian Multi-Vendor E-commerce Marketplace
// Prisma schema. Database: PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum VendorSaleType {
  RETAIL    // بالتجزئة
  WHOLESALE // بالجملة
  BOTH      // الاثنان معاً
}

/// خطة اشتراك البائعين في المنصة (بديلاً عن العمولة)
model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  durationDays  Int      @default(30)
  productLimit  Int?
  features      String[]
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  vendors       Vendor[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("subscription_plans")
}

enum ProductStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum OrderStatus {
  PENDING        // بانتظار التأكيد
  CONFIRMED      // مؤكد
  PROCESSING     // قيد التحضير
  SHIPPED        // تم الشحن
  DELIVERED      // تم التسليم
  CANCELLED      // ملغى
  RETURNED       // مرتجع
}

enum PaymentMethod {
  COD            // الدفع عند الاستلام
  CIB            // بطاقة CIB عبر SATIM
  EDAHABIA       // بطاقة الذهبية
  BARIDIMOB      // BaridiMob
  CCP            // تحويل بريدي CCP
  WALLET         // المحفظة
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShippingType {
  HOME           // التوصيل للمنزل
  STOPDESK       // مكتب التوصيل
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ============================================================
// Users & Auth
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String    @unique
  passwordHash  String
  fullName      String
  role          UserRole  @default(CUSTOMER)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)

  vendor        Vendor?
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  cart          Cart?
  wishlist      WishlistItem[]
  wallet        Wallet?
  refreshTokens RefreshToken[]
  notifications Notification[]
  sentMessages  ChatMessage[]  @relation("SentMessages")
  conversationsAsCustomer Conversation[] @relation("CustomerConversations")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  purpose   String   // verify_phone | reset_password
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otps")
}

// ============================================================
// Geography (Algeria - 58 wilayas + communes)
// ============================================================

model Wilaya {
  id        Int       @id   // official code 1..58
  nameAr    String
  nameFr    String
  communes  Commune[]
  shippingRates ShippingRate[]
  addresses Address[]

  @@map("wilayas")
}

model Commune {
  id        Int      @id @default(autoincrement())
  nameAr    String
  nameFr    String
  wilayaId  Int
  wilaya    Wilaya   @relation(fields: [wilayaId], references: [id])
  addresses Address[]

  @@index([wilayaId])
  @@map("communes")
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName   String
  phone      String
  wilayaId   Int
  wilaya     Wilaya   @relation(fields: [wilayaId], references: [id])
  communeId  Int?
  commune    Commune? @relation(fields: [communeId], references: [id])
  street     String?
  isDefault  Boolean  @default(false)
  orders     Order[]
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// Vendors (Multi-vendor)
// ============================================================

model Vendor {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName       String
  slug            String       @unique
  description     String?
  logoUrl         String?
  bannerUrl       String?
  status          VendorStatus @default(PENDING)
  commissionRate  Decimal      @default(0) @db.Decimal(5, 2) // % (النموذج الآن اشتراك بدل العمولة)
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  rating          Decimal      @default(0) @db.Decimal(3, 2)
  ratingCount     Int          @default(0)
  // contact / legal
  contactPhone    String?
  contactEmail    String?
  rcNumber        String?      // السجل التجاري
  nif             String?      // رقم التعريف الجبائي
  idCardUrl       String?      // صورة بطاقة هوية البائع (للتحقق)
  saleType        VendorSaleType @default(BOTH) // نوع البيع: تجزئة/جملة/كلاهما
  // payout info
  ccpAccount      String?
  ccpName         String?

  products        Product[]
  orderItems      OrderItem[]
  payouts         Payout[]
  conversations   Conversation[] @relation("VendorConversations")
  shippingRates   ShippingRate[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@map("vendors")
}

// ============================================================
// Catalog
// ============================================================

model Category {
  id          String     @id @default(cuid())
  nameAr      String
  nameFr      String?
  slug        String     @unique
  iconUrl     String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())

  @@index([parentId])
  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  vendorId      String
  vendor        Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  name          String
  slug          String        @unique
  description   String?
  type          ProductType   @default(SIMPLE)
  status        ProductStatus @default(DRAFT)
  // pricing for SIMPLE products
  price         Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?     @db.Decimal(12, 2)
  sku           String?
  barcode       String?
  stock         Int           @default(0)
  weightGrams   Int?
  rating        Decimal       @default(0) @db.Decimal(3, 2)
  ratingCount   Int           @default(0)
  soldCount     Int           @default(0)

  images        ProductImage[]
  variants      ProductVariant[]
  reviews       Review[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int     @default(0)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String  // e.g. "احمر / L"
  // attributes JSON e.g. { "اللون": "احمر", "المقاس": "L" }
  attributes Json
  price     Decimal @db.Decimal(12, 2)
  sku       String?
  barcode   String?
  stock     Int     @default(0)
  imageUrl  String?

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ============================================================
// Cart & Wishlist
// ============================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id         String          @id @default(cuid())
  cartId     String
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int             @default(1)

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ============================================================
// Orders
// ============================================================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  status          OrderStatus   @default(PENDING)
  // pricing
  subtotal        Decimal       @db.Decimal(12, 2)
  shippingFee     Decimal       @db.Decimal(12, 2) @default(0)
  discount        Decimal       @db.Decimal(12, 2) @default(0)
  total           Decimal       @db.Decimal(12, 2)
  // shipping
  shippingType    ShippingType  @default(HOME)
  courier         String?       // Yalidine | ZRExpress | ...
  trackingNumber  String?
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  notes           String?

  items           OrderItem[]
  payment         Payment?
  statusHistory   OrderStatusHistory[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  vendorId   String
  vendor     Vendor          @relation(fields: [vendorId], references: [id])
  productName String
  unitPrice  Decimal         @db.Decimal(12, 2)
  quantity   Int
  commission Decimal         @db.Decimal(12, 2) @default(0)

  @@index([orderId])
  @@index([vendorId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================
// Payments
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(12, 2)
  transactionRef String?
  providerData  Json?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Payout {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING") // PENDING | PAID
  method      String?  // CCP | BaridiMob
  reference   String?
  periodStart DateTime?
  periodEnd   DateTime?
  createdAt   DateTime @default(now())

  @@index([vendorId])
  @@map("payouts")
}

// ============================================================
// Wallet (المحفظة)
// ============================================================

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  transactions WalletTransaction[]
  updatedAt    DateTime            @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id          String          @id @default(cuid())
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  reference   String?
  createdAt   DateTime        @default(now())

  @@index([walletId])
  @@map("wallet_transactions")
}

// ============================================================
// Shipping (Algeria couriers + per-wilaya rates)
// ============================================================

model ShippingRate {
  id          String       @id @default(cuid())
  // null vendorId = platform default rate
  vendorId    String?
  vendor      Vendor?      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wilayaId    Int
  wilaya      Wilaya       @relation(fields: [wilayaId], references: [id])
  homePrice   Decimal      @db.Decimal(12, 2)
  stopdeskPrice Decimal    @db.Decimal(12, 2)
  etaDays     Int?

  @@unique([vendorId, wilayaId])
  @@index([wilayaId])
  @@map("shipping_rates")
}

// ============================================================
// Reviews
// ============================================================

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

// ============================================================
// Coupons
// ============================================================

model Coupon {
  id           String     @id @default(cuid())
  code         String     @unique
  type         CouponType @default(PERCENTAGE)
  value        Decimal    @db.Decimal(12, 2)
  minOrder     Decimal?   @db.Decimal(12, 2)
  maxDiscount  Decimal?   @db.Decimal(12, 2)
  usageLimit   Int?
  usedCount    Int        @default(0)
  vendorId     String?    // null = platform-wide
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean    @default(true)
  orders       Order[]
  createdAt    DateTime   @default(now())

  @@map("coupons")
}

// ============================================================
// Chat (buyer <-> seller)
// ============================================================

model Conversation {
  id         String        @id @default(cuid())
  customerId String
  customer   User          @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  vendorId   String
  vendor     Vendor        @relation("VendorConversations", fields: [vendorId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]
  updatedAt  DateTime      @updatedAt
  createdAt  DateTime      @default(now())

  @@unique([customerId, vendorId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("general")
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}
