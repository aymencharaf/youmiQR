{
  "name": "youmi",
  "version": "0.1.0",
  "private": true,
  "description": "Youmi - Algerian multi-vendor e-commerce marketplace",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @youmi/db prisma:generate",
    "db:migrate": "pnpm --filter @youmi/db prisma:migrate",
    "db:seed": "pnpm --filter @youmi/db prisma:seed",
    "db:studio": "pnpm --filter @youmi/db prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=20"
  }
}
